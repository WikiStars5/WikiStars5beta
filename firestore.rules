rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin.
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the 'figures' collection
    match /figures/{figureId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      
      // Allow updates if the user is an admin OR if they are only updating the count fields.
      // This is the key change to allow users to submit comments and ratings that update totals.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'commentCount', 'starRatingCounts', 'attitudeCounts', 'perceptionCounts'
        ])
      );
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Only admins can see the full list of users.
      allow list: if isAdmin();
      // Users can read their own profile, and admins can read any profile.
      allow read: if request.auth.uid == userId || isAdmin();
      // Users can update their own profile. Creation is handled by a Cloud Function.
      allow update: if request.auth.uid == userId;
      // No one can create or delete user profiles directly from the client.
      allow create, delete: if false;
    }

    // Rules for comments
    match /userComments/{commentId} {
      // Anyone can read comments.
      allow read: if true;
      // Any authenticated user (including anonymous) can create a comment.
      allow create: if request.auth.uid != null;
      // Only the author of the comment or an admin can update or delete it.
      allow update, delete: if resource.data.userId == request.auth.uid || isAdmin();
    }
    
    // Rules for notifications
    match /notifications/{notificationId} {
      // Users can only read their own notifications. Admins can read all for debugging.
      allow read: if resource.data.userId == request.auth.uid || isAdmin();
      // Only the server (via Cloud Functions) can create notifications.
      allow write: if false;
    }

    // Generic rules for user-specific subcollections (ratings, attitudes, etc.)
    match /userStarRatings/{ratingId} {
      allow read, write: if request.auth.uid != null && ratingId.split('_')[0] == request.auth.uid;
    }
    match /userAttitudes/{attitudeId} {
      allow read, write: if request.auth.uid != null && attitudeId.split('_')[0] == request.auth.uid;
    }
     match /userPerceptions/{perceptionId} {
      allow read, write: if request.auth.uid != null && perceptionId.split('_')[0] == request.auth.uid;
    }
  }
}
