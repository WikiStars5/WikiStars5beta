rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin.
    // An admin's user document must exist in /users/{userId} and have the role 'admin'.
    function isAdmin(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    // Helper function to check if the user is the owner of a document.
    function isOwner(docId) {
      return request.auth.uid == docId;
    }
    
    // Helper function to check if the user is authenticated (includes anonymous).
    function isAuthenticated() {
        return request.auth != null;
    }

    // Rules for the 'figures' collection
    match /figures/{figureId} {
      allow read: if true;
      allow create, delete: if isAdmin(request.auth.uid);
      
      // Allow updates only if the user is an admin, OR if they are only changing specific counter fields.
      allow update: if isAdmin(request.auth.uid) || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'commentCount', 'starRatingCounts', 'attitudeCounts', 'perceptionCounts'
        ])
      );
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin(request.auth.uid);
      allow update: if isOwner(userId);
      // Create is handled by a Cloud Function (onUserCreate) so we don't need a client rule for it.
      allow create, delete: if isAdmin(request.auth.uid);
    }
    
    // Rules for user-generated content
    match /userComments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated(); // Any authenticated user (including anonymous) can create
      allow update(text): if isOwner(resource.data.userId); // Allow owner to edit their own comment text
      // Allow owner OR an admin to delete
      allow delete: if isOwner(resource.data.userId) || isAdmin(request.auth.uid);
    }

    match /userAttitudes/{attitudeId} {
      allow read: if true;
      allow write: if isOwner(request.resource.data.userId); // User can only write their own attitude
    }

    match /userPerceptions/{perceptionId} {
      allow read: if true;
      allow write: if isOwner(request.resource.data.userId); // User can only write their own perception
    }
    
    match /userStarRatings/{ratingId} {
      allow read: if true;
      allow write: if isOwner(request.resource.data.userId); // User can only write their own rating
    }

    // Rules for notifications
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if isAuthenticated(); // Allow server-side creation (or any auth user)
    }
  }
}
