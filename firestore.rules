
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isRequestingUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use the hardcoded Admin UID for a reliable and secure check.
      return request.auth != null && request.auth.uid == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2';
    }

    // --- Collection: figures ---
    match /figures/{figureId} {
      allow read: if true;

      // Only admins can create or delete figures.
      allow create, delete: if isAdmin();
      
      // Update is allowed if:
      // 1. The user is an admin (can change anything).
      // 2. A non-admin is ONLY updating the vote/comment counter fields.
      allow update: if 
        isAdmin() || 
        (
          request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'attitudeCounts', 'perceptionCounts', 'starRatingCounts', 'commentCount'
          ])
        );
    }

    // --- Collection: users ---
    match /users/{userId} {
      // Allow a user to read their own profile, or an admin to read any profile.
      allow read: if isRequestingUser(userId) || isAdmin();
      
      // A user can only write to their own profile.
      // Creation is handled by the createProfileOnRegister Cloud Function.
      allow write: if isRequestingUser(userId);
    }
    
    // --- Collection: userComments ---
    match /userComments/{commentId} {
      allow read: if true;
      
      // Any authenticated user (including anonymous) can create a comment.
      allow create: if request.auth != null;
      
      // Allow update only if:
      // 1. The user is an admin.
      // 2. The user is updating their OWN comment (this is not currently used in the app, but is a safe rule).
      // 3. ANY authenticated user is ONLY incrementing the replyCount. This is the key fix.
      allow update: if 
        isAdmin() || 
        (isRequestingUser(resource.data.userId)) ||
        (
          request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']) &&
          request.resource.data.replyCount == resource.data.replyCount + 1
        );
        
      // Allow delete if the user is the owner of the comment OR is an admin.
      allow delete: if isRequestingUser(resource.data.userId) || isAdmin();
    }
    
    // --- Collections for Votes ---
    // These collections store individual user votes. A user should only be able
    // to manage their own vote documents.
    match /userAttitudes/{docId} {
      allow read, write: if request.auth != null && isRequestingUser(docId.split('_')[0]);
    }
    
    match /userPerceptions/{docId} {
      allow read, write: if request.auth != null && isRequestingUser(docId.split('_')[0]);
    }
    
    match /userStarRatings/{docId} {
      allow read, write: if request.auth != null && isRequestingUser(docId.split('_')[0]);
    }
    
    // --- Collection: notifications ---
    match /notifications/{notificationId} {
      // A user can only interact with their own notifications.
      // Creation is handled by a server-side process (Cloud Function/Action).
      allow create: if request.auth != null; // Allows server actions to create notifications
      allow read, update, delete: if request.auth != null && isRequestingUser(resource.data.userId);
    }
  }
}
