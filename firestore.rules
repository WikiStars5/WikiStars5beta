
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Figuras Públicas ---
    // Cualquiera puede leer, solo los administradores pueden escribir.
    match /figures/{figureId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Reseñas (Comentarios y Calificaciones) ---
    // Un usuario autenticado puede crear reseñas.
    // Solo el dueño original o un admin puede modificar o borrar su reseña.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- Perfiles de Usuario ---
    // Cualquiera puede leer perfiles.
    // Un usuario solo puede crear y actualizar su propio perfil.
    // Los administradores pueden actualizar cualquier perfil.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- Votos de Actitud ---
    // Un usuario solo puede leer y escribir su propio voto de actitud.
    match /userAttitudes/{voteId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // --- Votos de Percepción (Emociones) ---
    // Un usuario solo puede leer y escribir su propio voto de emoción.
    match /userPerceptions/{voteId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // --- Calificaciones con Estrellas ---
    // Un usuario solo puede leer y escribir su propia calificación.
    match /userStarRatings/{ratingId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // --- Notificaciones ---
    // Los usuarios solo pueden leer y actualizar sus propias notificaciones.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      // Nadie más que el servidor puede crear notificaciones.
      allow create: if false; 
    }
  }
}
