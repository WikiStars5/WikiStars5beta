
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is an admin
    function isAdmin(userId) {
      // The admin UID is hardcoded for security and simplicity.
      return userId == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2' || get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Figures can be read by anyone, but only modified by admins.
    match /figures/{figureId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin(request.auth.uid);
    }

    // Users can read/write their own profile. Admins can read any profile.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);
      allow write: if request.auth.uid == userId;
      // Admin-only operations are handled by Cloud Functions with admin privileges.
    }
    
    // Comments can be read by anyone.
    // Creation, update (likes), and deletion have specific rules.
    match /userComments/{commentId} {
      allow read: if true;
      allow list: if true;
      // Any authenticated user (including anonymous) can create a comment.
      allow create: if isAuthenticated();
      // Only authenticated users can update (for likes/dislikes).
      allow update: if isAuthenticated();
      // Only the author of the comment or an admin can delete it.
      allow delete: if request.auth.uid == resource.data.userId || isAdmin(request.auth.uid);
    }
    
    // User-specific data for ratings, attitudes, and perceptions.
    // Users can only create, update, or delete their own records.
    match /userStarRatings/{ratingId} {
      allow read, write: if isAuthenticated() && ratingId.startsWith(request.auth.uid);
    }
    
    match /userAttitudes/{attitudeId} {
      allow read, write: if isAuthenticated() && attitudeId.startsWith(request.auth.uid);
    }
    
    match /userPerceptions/{perceptionId} {
       allow read, write: if isAuthenticated() && perceptionId.startsWith(request.auth.uid);
    }
    
    // Notifications can only be read or updated (marked as read) by the recipient.
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Creation is handled by Cloud Functions.
      allow create: if false; 
      allow delete: if false;
    }
  }
}
