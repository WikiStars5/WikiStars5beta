rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin(userId) {
      // User is admin if their UID is the admin UID OR their role in Firestore is 'admin'.
      return request.auth.uid == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2' || get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    // Collection: figures
    match /figures/{figureId} {
      allow read: if true;
      allow create, delete: if isAdmin(request.auth.uid);
      
      // Allow updates if the user is an admin OR if the update only affects the allowed counter fields.
      allow update: if isAdmin(request.auth.uid) || (
          isUserAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['attitudeCounts', 'perceptionCounts', 'starRatingCounts', 'commentCount'])
      );
    }

    // Collection: users
    match /users/{userId} {
      allow read: if isAdmin(request.auth.uid) || isOwner(userId);
      allow write: if isOwner(userId); // Creation is handled by Cloud Function
    }

    // Collection: userComments
    match /userComments/{commentId} {
      allow read: if true;
      allow create: if isUserAuthenticated();
      allow update: if isOwner(request.resource.data.userId);
       // Allow delete if the user is the owner OR is an admin
      allow delete: if isOwner(resource.data.userId) || isAdmin(request.auth.uid);
    }
    
    // Collections for user-specific votes/ratings
    match /userAttitudes/{docId} {
      allow read, write: if isUserAuthenticated() && isOwner(docId.split('_')[0]);
    }

    match /userPerceptions/{docId} {
       allow read, write: if isUserAuthenticated() && isOwner(docId.split('_')[0]);
    }
    
    match /userStarRatings/{docId} {
       allow read, write: if isUserAuthenticated() && isOwner(docId.split('_')[0]);
    }

    // Collection: notifications
    match /notifications/{notificationId} {
      allow read, update: if isUserAuthenticated() && isOwner(resource.data.userId);
      // No one should be able to create notifications directly from the client.
      // This is handled by a secure Cloud Function.
      allow create, delete: if false; 
    }
  }
}
