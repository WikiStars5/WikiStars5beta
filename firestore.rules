rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================================================
    // ADVERTENCIA: REGLAS INSEGURAS - SOLO PARA DESARROLLO
    // Estas reglas son extremadamente permisivas y están destinadas
    // ÚNICAMENTE para la fase de desarrollo y pruebas para evitar
    // errores de permisos.
    // NO UTILICES ESTAS REGLAS EN UN ENTORNO DE PRODUCCIÓN.
    // =================================================================

    function isAdmin() {
      // Un administrador es aquel cuyo UID coincide con el ID de administrador predefinido.
      return request.auth != null && request.auth.uid == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2';
    }

    // Reglas para la colección de figuras.
    match /figures/{figureId} {
      // Cualquiera puede leer la información de las figuras.
      allow read: if true;
      // Cualquiera puede escribir/actualizar. CUIDADO EN PRODUCCIÓN.
      allow write: if request.auth != null;
    }

    // Reglas para los perfiles de usuario.
    match /users/{userId} {
       // Cualquiera puede leer/escribir. CUIDADO EN PRODUCCIÓN.
      allow read, write: if request.auth != null;
    }

    // Reglas para los comentarios de los usuarios.
    match /userComments/{commentId} {
      // Cualquiera puede leer.
      allow read: if true;
      // Cualquiera puede crear, actualizar y borrar. CUIDADO EN PRODUCCIÓN.
      allow write: if request.auth != null;
    }

    // Reglas para las calificaciones con estrellas.
    match /userStarRatings/{ratingId} {
      // Cualquiera puede leer y escribir. CUIDADO EN PRODUCCIÓN.
      allow read, write: if request.auth != null;
    }

    // Reglas para los votos de actitud.
    match /userAttitudes/{attitudeId} {
       // Cualquiera puede leer y escribir. CUIDADO EN PRODUCCIÓN.
      allow read, write: if request.auth != null;
    }

    // Reglas para los votos de percepción emocional.
    match /userPerceptions/{perceptionId} {
       // Cualquiera puede leer y escribir. CUIDADO EN PRODUCCIÓN.
      allow read, write: if request.auth != null;
    }

    // Reglas para las notificaciones.
    match /notifications/{notificationId} {
       // Cualquiera puede leer y escribir. CUIDADO EN PRODUCCIÓN.
      allow read, write: if request.auth != null;
    }
  }
}
