rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check for admin role (direct UID check for reliability)
    function isAdmin() {
      return request.auth.uid == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2';
    }

    // Figures: Public can read, only admin can create/delete. Update is conditional.
    match /figures/{figureId} {
      allow read: if true;
      allow create, delete: if isAdmin();

      // Allow admins to update anything.
      // Allow any authenticated user to update ONLY the counter fields.
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'perceptionCounts', 'attitudeCounts', 'starRatingCounts', 'commentCount'
        ])
      );
    }

    // User Profiles: Users can manage their own profile. Admins can view all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // User Comments: Authenticated users can create. Owner or admin can delete.
    // Update is allowed by owner, or to increment replyCount.
    match /userComments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      
      // Allow update if user is owner, admin, or ONLY updating the replyCount.
      allow update: if (isOwner(resource.data.userId) || isAdmin()) ||
                      (request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']));
                      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // User Ratings/Attitudes/Perceptions: Users can manage their own votes.
    match /userStarRatings/{ratingId} {
      allow read, write, delete: if isOwner(ratingId.split('_')[0]);
    }
    match /userAttitudes/{attitudeId} {
      allow read, write, delete: if isOwner(attitudeId.split('_')[0]);
    }
    match /userPerceptions/{perceptionId} {
       allow read, write, delete: if isOwner(perceptionId.split('_')[0]);
    }

    // Notifications: Users can only read their own. Creation is handled by server.
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false; // Should only be written by Cloud Functions
    }
  }
}
