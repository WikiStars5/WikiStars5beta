
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isAdmin() {
      // Check if the user is authenticated and their profile document has the 'admin' role.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /figures/{figureId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      // Anyone can create their own user document during signup.
      allow create: if true; 
      // Only the owner or an admin can view a user profile.
      allow get: if isOwner(userId) || isAdmin();
      // Only the owner or an admin can list all users.
      allow list: if isAdmin();
      // Only the owner can update their own profile.
      allow update: if isOwner(userId);
      // Only an admin can delete a user.
      allow delete: if isAdmin();
    }

    match /userPerceptions/{docId} { allow read, write: if isAuthenticated(); }
    match /userAttitudes/{docId} { allow read, write: if isAuthenticated(); }
    match /userStarRatings/{docId} { allow read, write: if isAuthenticated(); }

    match /userComments/{commentId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /notifications/{notificationId} {
      // The backend function creates notifications, not the client directly
      allow create: if false; 
      allow list, read, update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
