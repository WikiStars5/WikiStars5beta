rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Figures can be read by anyone, but only admins (via Cloud Functions) can write.
    match /figures/{figureId} {
      allow read: if true;
      // Admin-only write access is enforced by Cloud Functions running with a service account.
      // We deny direct client writes for security.
      allow write: if false; 
    }
    
    // User profiles can be read by anyone.
    // Users can only update their own profile. Creation is handled by Cloud Functions.
    match /users/{userId} {
      allow read: if true;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if false;
    }

    // New rule for reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Any authenticated user (including anonymous) can create a review
      allow create: if request.auth != null;
      // Only the user who created the review can update or delete it.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Notifications are private to each user.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if true; // Notifications are created by server-side logic (triggers).
    }
    
    // User perceptions and attitudes are private write, public read.
    match /userPerceptions/{voteId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /userAttitudes/{voteId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

  }
}
