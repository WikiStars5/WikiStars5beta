
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuth() {
      return request.auth != null;
    }

    // Explicitly check for the Admin UID. This is the most reliable method.
    function isRequestingAdmin() {
      return request.auth.uid == 'JZP4A5GvZUbWuT0Y1DIiawWcSUp2';
    }

    // --- Collections ---

    match /figures/{figureId} {
      allow read;
      allow create, delete: if isRequestingAdmin();

      // Allow updates if the user is an admin, OR if a regular user is only updating the counter fields.
      allow update: if isRequestingAdmin() || 
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['commentCount', 'starRatingCounts', 'attitudeCounts', 'perceptionCounts']));
    }
    
    match /users/{userId} {
      allow read, update: if isAuth() && request.auth.uid == userId;
      allow list: if isRequestingAdmin();
    }
    
    match /userComments/{commentId} {
      allow read;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.userId;
      
      // Allow delete if the user is the owner OR the user is the Admin.
      allow delete: if isAuth() && (request.auth.uid == resource.data.userId || isRequestingAdmin());
    }
    
    match /userAttitudes/{attitudeId} {
      allow read, write: if isAuth() && request.auth.uid == request.resource.data.userId;
    }
    
    match /userStarRatings/{ratingId} {
      allow read, write: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /userPerceptions/{perceptionId} {
       allow read, write: if isAuth() && request.auth.uid == request.resource.data.userId;
    }
    
    match /notifications/{notificationId} {
        allow read, update: if isAuth() && request.auth.uid == resource.data.userId;
        allow create: if isAuth(); // Functions create notifications, users read/update them.
    }
  }
}
