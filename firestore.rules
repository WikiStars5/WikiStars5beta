rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // WARNING: These rules are simplified for development and debugging.
    // They allow broad access and should be secured before moving to production.

    // Allow read access to everyone for all documents.
    // Allow write access to any authenticated user (including anonymous) for all documents.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
