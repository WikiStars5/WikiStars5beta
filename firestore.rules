
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite la lectura de perfiles de usuario, figuras y hashtags por cualquier persona.
    match /users/{userId} {
      allow read, create; 
      allow update: if request.auth.uid == userId;
    }
    match /figures/{figureId} {
      allow read, list;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
     match /figures/{figureId}/{subcollection}/{documentId} {
      allow read, list;
      allow write: if request.auth != null;
    }
    match /hashtags/{hashtagId} {
      allow read, list;
       allow write: if request.auth != null; // Allow logged-in users to create hashtags
    }
    
    // Reglas para Notificaciones
    match /notifications/{notificationId} {
      // Las funciones de backend pueden crear notificaciones.
      // Los usuarios autenticados pueden leer sus propias notificaciones.
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;

      // Un usuario solo puede actualizar un documento si el `userId` del documento
      // coincide con su propio ID de autenticación.
      // Usamos request.resource.data en lugar de resource.data para mayor robustez.
      allow update: if request.auth.uid == request.resource.data.userId;
    }

    // Reglas para Calificaciones de Estrellas (userRatings)
    match /userRatings/{ratingId} {
      // Un usuario puede crear, leer o actualizar su propia calificación
      allow read, write: if request.auth.uid == request.resource.data.userId;
    }
  }
}
